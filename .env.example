# PostgreSQL connection string (host port 5435 maps to container port 5432 — see docker-compose.yml)
DATABASE_URL=postgres://wallet:wallet@localhost:5435/wallet

# Redis connection for BullMQ job queue
REDIS_HOST=localhost
REDIS_PORT=6379

# Platform account UUID — the system user that receives royalties
PLATFORM_ACCOUNT_ID=00000000-0000-0000-0000-000000000001

# Platform wallet UUID — the wallet credited with platform royalty fees
PLATFORM_WALLET_ID=00000000-0000-0000-0000-000000000002
